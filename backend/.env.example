# ============================================================
# Django
# ============================================================
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ============================================================
# Database — local PostgreSQL (no Docker)
# ============================================================
# Option A: single connection URL (takes precedence if set)
# DATABASE_URL=postgresql://musicuser:musicpassword@localhost:5432/musicdb

# Option B: individual vars (used when DATABASE_URL is absent or empty)
POSTGRES_DB=musicdb
POSTGRES_USER=musicuser
POSTGRES_PASSWORD=musicpassword
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ============================================================
# Generation strategy
# ============================================================
# "suno"  — use the real Suno API
# "mock"  — return a fake MP3 URL (useful for local dev/tests)
GENERATOR_STRATEGY=mock
MOCK_SONG_AUDIO_URL=https://example.com/mock/generated-song.mp3

SUNO_API_KEY=your-suno-api-key-here
SUNO_API_BASE_URL=https://api.sunoapi.org/api/v1
SUNO_CALLBACK_URL=http://localhost:8000/api/suno/callback/

# ============================================================
# Google OAuth 2.0
# ============================================================
GOOGLE_OAUTH_CLIENT_ID=your-google-oauth-client-id
GOOGLE_OAUTH_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/api/auth/google/callback/
